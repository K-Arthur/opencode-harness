{
  "name": "opencode-harness",
  "displayName": "OpenCode",
  "publisher": "opencode-harness",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USER/opencode-harness"
  },
  "description": "AI coding agent for your editor — write, refactor, test, and debug with natural language commands",
  "version": "0.0.1",
  "engines": { "vscode": "^1.98.0" },
  "categories": ["Chat", "AI"],
  "activationEvents": [
    "onView:opencode-harness.chat",
    "onCommand:opencode-harness.openChat"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "opencode-harness.openChat", "title": "OpenCode: Open Chat" },
      { "command": "opencode-harness.newSession", "title": "OpenCode: New Session" },
      { "command": "opencode-harness.toggleFocus", "title": "OpenCode: Toggle Chat Focus" },
      { "command": "opencode-harness.explainCode", "title": "OpenCode: Explain Code" },
      { "command": "opencode-harness.refactorCode", "title": "OpenCode: Refactor Code" },
      { "command": "opencode-harness.generateTests", "title": "OpenCode: Generate Tests" },
      { "command": "opencode-harness.insertMention", "title": "OpenCode: Insert File Reference" },
      { "command": "opencode-harness.captureTerminal", "title": "OpenCode: Capture Terminal Output" },
      { "command": "opencode-harness.rollback", "title": "OpenCode: Rollback Changes" },
      { "command": "opencode-harness.showRateLimits", "title": "OpenCode: Show Rate Limits" }
    ],
    "keybindings": [
      { "command": "opencode-harness.toggleFocus", "key": "ctrl+alt+o" },
      { "command": "opencode-harness.newSession", "key": "ctrl+alt+n" },
      { "command": "opencode-harness.insertMention", "key": "alt+k", "when": "editorTextFocus" }
    ],
    "viewsContainers": {
      "auxiliarybar": [{
        "id": "opencode-harness",
        "title": "OpenCode Harness",
        "icon": "$(symbol-operator)"
      }]
    },
    "views": {
      "opencode-harness": [
        { "id": "opencode-harness.chat", "name": "Chat", "type": "webview" },
        { "id": "opencode-harness.sessions", "name": "Sessions" },
        { "id": "opencode-harness.skills", "name": "Skills" }
      ]
    },
    "menus": {
      "editor/context": [
        { "command": "opencode-harness.explainCode", "group": "opencode@1", "when": "editorHasSelection" },
        { "command": "opencode-harness.refactorCode", "group": "opencode@2", "when": "editorHasSelection" },
        { "command": "opencode-harness.generateTests", "group": "opencode@3", "when": "editorHasSelection" }
      ]
    }
  },
  "configuration": {
    "title": "OpenCode",
    "properties": {
      "opencode.theme": {
        "type": "object",
        "default": { "preset": "cli-default", "overrides": {} },
        "description": "Theme configuration for the OpenCode chat panel. Set 'preset' to one of: cli-default, light, dark, high-contrast. Add 'overrides' with specific color overrides.",
        "properties": {
          "preset": {
            "type": "string",
            "enum": ["cli-default", "light", "dark", "high-contrast"],
            "default": "cli-default",
            "description": "Base theme preset"
          },
          "overrides": {
            "type": "object",
            "default": {},
            "description": "Individual color overrides for the theme (e.g. userMessageBg, toolReadColor, syntaxKeyword, etc.)",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "opencode.rateLimits": {
        "type": "object",
        "default": {},
        "description": "Fallback rate limit configuration per provider. Set tokensPerMin and requestsPerMin for providers that don't return headers (e.g. openai, anthropic).",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "tokensPerMin": { "type": "number", "default": 100000, "description": "Maximum tokens per minute for this provider" },
            "requestsPerMin": { "type": "number", "default": 50, "description": "Maximum requests per minute for this provider" }
          }
        }
      },
      "opencode.rateLimitWarningThreshold": {
        "type": "number",
        "default": 0.1,
        "description": "Fraction of remaining rate limit that triggers a warning notification (0.0–1.0)"
      },
      "opencode.rateLimitCriticalThreshold": {
        "type": "number",
        "default": 0.05,
        "description": "Fraction of remaining rate limit that triggers a critical warning (0.0–1.0)"
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.98.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.14.33",
    "simple-git": "^3.27.0"
  }
}
