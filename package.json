                },
                "markdownImageText": {
                  "type": "string",
                  "description": "Markdown image text color"
                },
                "markdownCodeBlock": {
                  "type": "string",
                  "description": "Markdown fenced code color"
                },
                "syntaxVariable": {
                  "type": "string",
                  "description": "Syntax highlight color for variables"
                },
                "syntaxPunctuation": {
                  "type": "string",
                  "description": "Syntax highlight color for punctuation"
                }
              },
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "opencode.model": {
          "type": "string",
          "default": "",
          "scope": "window",
          "description": "Default model ID in provider/model format (e.g. anthropic/claude-sonnet-4-20250514). Set via 'OpenCode: Select Model' command."
        },
        "opencode.contextWindowOverride": {
          "type": "number",
          "default": 0,
          "scope": "window",
          "description": "Override the context window limit for the active model. Set to 0 to use the server-reported value. Use this when the server doesn't report limit.context for your model."
        },
        "opencode.rateLimits": {
          "type": "object",
          "scope": "window",
          "default": {},
          "description": "Fallback rate limit configuration per provider. Set tokensPerMin and requestsPerMin for providers that don't return headers (e.g. openai, anthropic).",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "tokensPerMin": {
                "type": "number",
                "default": 100000,
                "description": "Maximum tokens per minute for this provider"
              },
              "requestsPerMin": {
                "type": "number",
                "default": 50,
                "description": "Maximum requests per minute for this provider"
              }
            }
          }
        },
        "opencode.rateLimitWarningThreshold": {
          "type": "number",
          "scope": "window",
          "default": 0.1,
          "description": "Warn when this fraction (0.0-1.0) of the rate limit remains. Example: 0.1 means 'warn at 10% remaining'."
        },
        "opencode.rateLimitCriticalThreshold": {
          "type": "number",
          "scope": "window",
          "default": 0.05,
          "description": "Fraction of remaining rate limit that triggers a critical warning (0.0-1.0)"
        },
        "opencode.inlineSuggestions.enabled": {
          "type": "boolean",
          "default": false,
          "scope": "window",
          "description": "[Preview] Enable inline ghost-text completions as you type. This feature is not yet fully implemented and is disabled by default."
        },
        "opencode.inlineSuggestions.triggerDelay": {
          "type": "number",
          "default": 300,
          "scope": "window",
          "description": "Milliseconds to wait after typing stops before requesting an inline completion."
        },
        "opencode.autoCompact": {
          "type": "string",
          "scope": "window",
          "default": "ask",
          "enum": [
            "ask",
            "auto",
            "off"
          ],
          "enumDescriptions": [
            "Show a confirmation prompt before auto-compacting the conversation history.",
            "Auto-compact the conversation history without asking when the threshold is reached.",
            "Never auto-compact. The session continues until the model's context limit is reached."
          ],
          "description": "Controls whether the conversation history is automatically summarized (compacted) when it reaches the configured threshold (opencode.autoCompactThreshold). Compaction saves tokens and prevents context-limit errors but discards some detail from earlier turns."
        },
        "opencode.autoCompactThreshold": {
          "type": "number",
          "scope": "window",
          "default": 80,
          "minimum": 10,
          "maximum": 95,
          "description": "Percent of the model's context window at which to trigger auto-compaction. Lower values compact earlier (saves cost / runs less risk of overflow); higher values keep more raw history before summarising. Values outside [10, 95] are clamped."
        },
        "opencode.autoCompactPerModelThreshold": {
          "type": "object",
          "scope": "window",
          "default": {},
          "additionalProperties": {
            "type": "number",
            "minimum": 10,
            "maximum": 95
          },
          "description": "Per-model overrides for the auto-compaction threshold. Keys are 'provider/modelId' (e.g. 'anthropic/claude-sonnet-4-6-20251015'), values are percent (10-95). Models without an entry use opencode.autoCompactThreshold."
        },
        "opencode.sessions.emptySessionTtlMinutes": {
          "type": "number",
          "scope": "window",
          "default": 60,
          "minimum": 1,
          "description": "Deletes completely empty, inactive sessions after this many minutes."
        },
        "opencode.sessions.cleanupIntervalMinutes": {
          "type": "number",
          "scope": "window",
          "default": 15,
          "minimum": 1,
          "description": "How often the extension prunes completely empty sessions."
        },
        "opencode.sessions.restoreOpenTabs": {
          "type": "boolean",
          "scope": "window",
          "default": true,
          "description": "Restore chat tabs that were open in this workspace when VS Code last exited."
        },
        "opencode.debugLogging": {
          "type": "boolean",
          "scope": "window",
          "default": false,
          "description": "Enable verbose debug logging to the OpenCode Harness output channel"
        },
        "opencode.toolOutput.renderAnsi": {
          "type": "boolean",
          "scope": "window",
          "default": false,
          "description": "Render ANSI color sequences in bash tool output (experimental — may affect performance)"
        },
        "opencode.tdd.enabled": {
          "type": "boolean",
          "scope": "window",
          "default": false,
          "description": "Enable Test-Driven Development orchestration. When enabled, coding tasks will follow Red-Green-Refactor cycles with automatic test generation and verification."
        },
        "opencode.tdd.minCoverage": {
          "type": "number",
          "scope": "window",
          "default": 80,
          "minimum": 0,
          "maximum": 100,
          "description": "Minimum test coverage percentage required to complete the TDD cycle."
        },
        "opencode.tdd.maxIterations": {
          "type": "number",
          "scope": "window",
          "default": 5,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum number of iterations allowed per TDD phase before marking it as failed."
        },
        "opencode.sadd.enabled": {
          "type": "boolean",
          "scope": "window",
          "default": false,
          "description": "Enable Sub-Agent Driven Development (SADD). When enabled, the AI decomposes complex tasks into parallel subtasks, each run by a separate sub-agent. This can speed up multi-file changes but uses more tokens."
        },
        "opencode.sadd.maxSubagents": {
          "type": "number",
          "scope": "window",
          "default": 4,
          "minimum": 1,
          "maximum": 8,
          "description": "Maximum number of sub-agents that can run in parallel for a single task when Sub-Agent Driven Development is enabled."
        },
        "opencode.methodology.enabled": {
          "type": "boolean",
          "scope": "window",
          "default": true,
          "description": "Enable automatic methodology guidance. When enabled, the extension classifies each prompt and attaches a short strategy hint (visible in the status strip; disable per tab with /methodology off)."
        },
        "opencode.sessions.maxConcurrentStreams": {
          "type": "number",
          "scope": "window",
          "default": 5,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum number of concurrent AI streams across all tabs."
        },
        "opencode.chat.wrapLongLines": {
          "type": "string",
          "default": "auto",
          "enum": [
            "on",
            "off",
            "auto"
          ],
          "enumDescriptions": [
            "Always wrap long lines in code blocks, diffs, and tool output.",
            "Never wrap — always use horizontal scrolling.",
            "Use per-context defaults: wrap markdown and diffs, scroll code."
          ],
          "scope": "window",
          "description": "Controls how long lines are displayed in code blocks, diffs, and tool output. 'auto' wraps conversational content but scrolls structured content like code."
        },
        "opencode.defaultMode": {
          "type": "string",
          "default": "build",
          "enum": [
            "plan",
            "build",
            "auto"
          ],
          "scope": "window",
          "description": "Default session mode for new chat sessions."
        },
        "opencode.modeModels": {
          "type": "object",
          "scope": "window",
          "default": {},
          "description": "Assign a different AI model to each session mode (Plan, Build, Auto). For example, use a cheaper model for Plan and a more capable model for Build. Each value must be a model ID in provider/model format (e.g. 'anthropic/claude-sonnet-4-20250514'). Leave a mode empty to use the session's default model.",
          "properties": {
            "plan": {
              "type": "string",
              "default": "",
              "description": "Model to use in Plan mode (e.g. 'anthropic/claude-sonnet-4-20250514'). When empty, uses the session's default model."
            },
            "build": {
              "type": "string",
              "default": "",
              "description": "Model to use in Build mode. When empty, uses the session's default model."
            },
            "auto": {
              "type": "string",
              "default": "",
              "description": "Model to use in Auto mode. When empty, uses the session's default model."
            }
          },
          "additionalProperties": false
        },
        "opencode.voice.enabled": {
          "type": "boolean",
          "scope": "window",
          "default": true,
          "description": "Show the microphone button in the chat composer. Voice input records the microphone and transcribes it locally on your machine — no cloud service or API key. The transcript is inserted into the prompt for review and is never auto-sent unless opencode.voice.autoSend is enabled."
        },
        "opencode.voice.autoSend": {
          "type": "boolean",
          "scope": "window",
          "default": false,
          "description": "Automatically send the prompt as soon as a voice transcript is inserted. Off by default so you can edit before sending."
        },
        "opencode.voice.language": {
          "type": "string",
          "scope": "window",
          "default": "auto",
          "description": "Spoken language passed to the local speech-to-text engine (e.g. 'en-US', 'es', 'fr'). Use 'auto' to let the engine detect the language."
        },
        "opencode.voice.insertMode": {
          "type": "string",
          "scope": "window",
          "default": "append",
          "enum": [
            "append",
            "replace"
          ],
          "enumDescriptions": [
            "Append the transcript to whatever is already in the prompt.",
            "Replace the prompt contents with the transcript."
          ],
          "description": "How a voice transcript is placed into the prompt box."
        },
        "opencode.voice.maxRecordingSeconds": {
          "type": "number",
          "scope": "window",
          "default": 60,
          "minimum": 1,
          "maximum": 300,
          "description": "Maximum length of a single voice recording. Recording stops automatically at this limit."
        },
        "opencode.voice.model": {
          "type": "string",
          "scope": "machine",
          "default": "",
          "markdownDescription": "Local speech-to-text model. For openai-whisper this is a model size (e.g. `base`, `small`); for whisper.cpp this is the path to a `.bin` model file (required to use whisper.cpp). Leave blank to use the openai-whisper `base` model. Machine-scoped so it cannot be set by an untrusted workspace."
        },
        "opencode.voice.localCommand": {
          "type": "string",
          "scope": "machine",
          "default": "",
          "markdownDescription": "Optional override command for local transcription (bring-your-own engine). Placeholders: `{input}` (audio WAV path), `{output}` (a .txt path the command may write the transcript to), `{language}`. If `{output}` is used the file is read; otherwise stdout is used. Example: `whisper-ctranslate2 {input} --language {language} --output_dir /tmp --output_format txt`. Machine-scoped for security: an untrusted workspace cannot set the command the host runs."
        },
        "opencode.voice.recordCommand": {
          "type": "string",
          "scope": "machine",
          "default": "",
          "markdownDescription": "Optional override command to record the microphone to a WAV file. Placeholders: `{output}` (target WAV path), `{duration}` (max seconds). The command should record the default input device and stop on SIGINT. Leave blank to auto-detect `rec` (sox), `arecord`, or `ffmpeg`. Machine-scoped for security."
        },
        "opencode.sessions.processStrategy": {
          "type": "string",
          "scope": "window",
          "default": "shared",
          "enum": [
            "shared",
            "per-tab"
          ],
          "enumDescriptions": [
            "All tabs share one opencode server process — uses less memory, safe for most workflows.",
            "Each tab gets its own opencode server process — full crash isolation but uses more memory."
          ],
          "description": "Process isolation strategy. 'shared' (default) = one server for all tabs. 'per-tab' = each tab gets its own server process for full crash isolation."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run typecheck && node esbuild.js --production && node scripts/check-bundle-size.mjs",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies",
    "reinstall": "node scripts/reinstall-extension.mjs",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "bundle:check": "node scripts/check-bundle-size.mjs",
    "bundle:attribute": "node scripts/bundle-attribution.mjs",
    "test:unit": "node --test tests/unit/*.test.mjs && npx tsx --test \"src/**/*.test.ts\"",
    "coverage": "c8 --reporter=text --include='**' --exclude='node_modules/**' --exclude='tests/**' --exclude='.git/**' --exclude='*.json' --exclude='*.md' --exclude='*.yaml' --exclude='*.html' node --test tests/unit/*.test.mjs",
    "test:integration": "vscode-test",
    "test:visual": "playwright test",
    "test:visual:context": "playwright test tests/visual/chat-context-usage.spec.ts --project=chromium",
    "test:visual:update": "playwright test --update-snapshots",
    "test:webview": "playwright test --project=chromium-webview",
    "test:message-contract": "npx tsx --test tests/webview/message-contract.test.ts",
    "test:roundtrip": "node --test tests/integration/message-roundtrip.test.mjs",
    "test": "npm run test:unit && npm run test:message-contract && npm run test:roundtrip"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@types/diff-match-patch": "^1.0.36",
    "@types/jsdom": "^28.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.19.17",
    "@types/vscode": "~1.98.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "c8": "^11.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "mocha": "^11.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.0"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.17.7",
    "dompurify": "^3.4.10",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.15.0"
  }
}
