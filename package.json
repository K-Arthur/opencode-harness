{
  "name": "opencode-harness",
  "displayName": "OpenCode - AI Coding Assistant for VS Code",
  "publisher": "koarthur",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/K-Arthur/opencode-harness"
  },
  "description": "Open-source AI coding agent for VS Code. Chat, refactor, debug, and write code using Claude, GPT, Gemini, and 75+ models. Includes cost tracking, custom themes, permission controls, and checkpoint rollback.",
  "icon": "media/opencode-icon-256.png",
  "version": "0.3.75",
  "engines": {
    "vscode": "^1.98.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true,
      "description": "Requires workspace access to read and modify files"
    }
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:opencode-harness.chatView"
  ],
  "categories": [
    "Programming Languages",
    "Chat",
    "Machine Learning"
  ],
  "keywords": [
    "opencode",
    "ai",
    "coding",
    "assistant",
    "vscode",
    "vs-code",
    "chat",
    "refactor",
    "debug",
    "llm",
    "anthropic",
    "claude",
    "openai",
    "gpt",
    "gemini",
    "model",
    "cost-tracking",
    "theme",
    "privacy"
  ],
  "galleryBanner": {
    "color": "#007acc",
    "theme": "dark"
  },
  "bugs": {
    "url": "https://github.com/K-Arthur/opencode-harness/issues"
  },
  "homepage": "https://github.com/K-Arthur/opencode-harness#readme",
  "extensionKind": [
    "workspace"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "opencode-harness.openChat",
        "title": "OpenCode: Open Chat"
      },
      {
        "command": "opencode-harness.newSession",
        "title": "OpenCode: New Session"
      },
      {
        "command": "opencode-harness.toggleFocus",
        "title": "OpenCode: Toggle Chat Focus"
      },
      {
        "command": "opencode-harness.explainCode",
        "title": "OpenCode: Explain Code"
      },
      {
        "command": "opencode-harness.refactorCode",
        "title": "OpenCode: Refactor Code"
      },
      {
        "command": "opencode-harness.generateTests",
        "title": "OpenCode: Generate Tests"
      },
      {
        "command": "opencode-harness.insertMention",
        "title": "OpenCode: Insert File Reference"
      },
      {
        "command": "opencode-harness.captureTerminal",
        "title": "OpenCode: Capture Terminal Output"
      },
      {
        "command": "opencode-harness.rollback",
        "title": "OpenCode: Rollback Changes"
      },
      {
        "command": "opencode-harness.showRateLimits",
        "title": "OpenCode: View Rate Limits"
      },
      {
        "command": "opencode-harness.selectModel",
        "title": "OpenCode: Choose Model"
      },
      {
        "command": "opencode-harness.setContextWindowOverride",
        "title": "OpenCode: Set Context Window Override"
      },
      {
        "command": "opencode-harness.checkCli",
        "title": "OpenCode: Test CLI Connection"
      },
      {
        "command": "opencode-harness.installCli",
        "title": "OpenCode: Install CLI"
      },
      {
        "command": "opencode-harness.listSessions",
        "title": "OpenCode: View Sessions"
      },
      {
        "command": "opencode-harness.openStoredSession",
        "title": "OpenCode: Open Stored Session"
      },
      {
        "command": "opencode-harness.deleteSession",
        "title": "OpenCode: Delete Session"
      },
      {
        "command": "opencode-harness.renameSession",
        "title": "OpenCode: Rename Session"
      },
      {
        "command": "opencode-harness.exportConversation",
        "title": "OpenCode: Export Conversation"
      },
      {
        "command": "opencode-harness.previewTheme",
        "title": "OpenCode: Preview Theme"
      },
      {
        "command": "opencode-harness.clearTestSessions",
        "title": "OpenCode: Clear Test Sessions"
      },
      {
        "command": "opencode-harness.continueLastSession",
        "title": "OpenCode: Continue Last Session"
      },
      {
        "command": "opencode-harness.chooseHistorySession",
        "title": "OpenCode: Open Past Session"
      },
      {
        "command": "opencode-harness.attachRemote",
        "title": "OpenCode: Connect to Remote Server"
      },
      {
        "command": "opencode-harness.addFileToSession",
        "title": "OpenCode: Add File to Session"
      },
      {
        "command": "opencode-harness.addSelectionToSession",
        "title": "OpenCode: Add Selection to Session"
      },
      {
        "command": "opencode-harness.stop",
        "title": "OpenCode: Stop"
      },
      {
        "command": "opencode-harness.quickChat",
        "title": "OpenCode: Quick Chat"
      },
      {
        "command": "opencode-harness.generateAgentsMd",
        "title": "OpenCode: Generate AGENTS.md"
      },
      {
        "command": "opencode-harness.openCommandsPalette",
        "title": "OpenCode: Open Commands Palette"
      },
      {
        "command": "opencode-harness.clearSession",
        "title": "OpenCode: Clear Active Session"
      },
      {
        "command": "opencode-harness.showCost",
        "title": "OpenCode: Show Session Cost"
      },
      {
        "command": "opencode-harness.showHelp",
        "title": "OpenCode: Show Slash Commands"
      },
      {
        "command": "opencode-harness.cycleMode",
        "title": "OpenCode: Cycle Session Mode (Plan → Build → Auto)"
      },
      {
        "command": "opencode-harness.setBuildMode",
        "title": "OpenCode: Set Session Mode to Build"
      },
      {
        "command": "opencode-harness.setPlanMode",
        "title": "OpenCode: Set Session Mode to Plan"
      },
      {
        "command": "opencode-harness.setAutoMode",
        "title": "OpenCode: Set Session Mode to Auto"
      },
      {
        "command": "opencode-harness.setDefaultMode",
        "title": "OpenCode: Set Default Session Mode"
      },
      {
        "command": "opencode-harness.setupVoiceInput",
        "title": "OpenCode: Set Up Voice Input"
      },
      {
        "command": "opencode-harness.retryLast",
        "title": "OpenCode: Retry Last Failed Run"
      },
      {
        "command": "opencode-harness.nextTab",
        "title": "OpenCode: Next Tab"
      },
      {
        "command": "opencode-harness.prevTab",
        "title": "OpenCode: Previous Tab"
      },
      {
        "command": "opencode-harness.openSettings",
        "title": "OpenCode: Open Settings"
      },
      {
        "command": "opencode-harness.jumpToRunningTask",
        "title": "OpenCode: Jump to Running Session"
      },
      {
        "command": "opencode-harness.suppressKey",
        "title": "OpenCode: (internal) Suppress conflicting key while chat focused"
      }
    ],
    "keybindings": [
      {
        "command": "opencode-harness.quickChat",
        "key": "ctrl+i",
        "when": "editorTextFocus"
      },
      {
        "command": "opencode-harness.toggleFocus",
        "key": "ctrl+alt+o"
      },
      {
        "command": "opencode-harness.newSession",
        "key": "ctrl+alt+n"
      },
      {
        "command": "opencode-harness.insertMention",
        "key": "alt+k",
        "when": "editorTextFocus"
      },
      {
        "command": "opencode-harness.stop",
        "key": "ctrl+shift+escape",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      },
      {
        "command": "opencode-harness.openCommandsPalette",
        "key": "ctrl+shift+/",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      },
      {
        "command": "opencode-harness.nextTab",
        "key": "ctrl+alt+]",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      },
      {
        "command": "opencode-harness.prevTab",
        "key": "ctrl+alt+[",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      },
      {
        "command": "opencode-harness.retryLast",
        "key": "ctrl+alt+r",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      },
      {
        "command": "opencode-harness.suppressKey",
        "key": "alt+1",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      },
      {
        "command": "opencode-harness.suppressKey",
        "key": "alt+2",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      },
      {
        "command": "opencode-harness.suppressKey",
        "key": "alt+3",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      },
      {
        "command": "opencode-harness.suppressKey",
        "key": "alt+shift+tab",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      },
      {
        "command": "opencode-harness.suppressKey",
        "key": "ctrl+shift+m",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      },
      {
        "command": "opencode-harness.suppressKey",
        "key": "ctrl+shift+t",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      },
      {
        "command": "opencode-harness.suppressKey",
        "key": "ctrl+t",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      },
      {
        "command": "opencode-harness.suppressKey",
        "key": "ctrl+w",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      },
      {
        "command": "opencode-harness.suppressKey",
        "key": "ctrl+tab",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      },
      {
        "command": "opencode-harness.suppressKey",
        "key": "ctrl+shift+tab",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      },
      {
        "command": "opencode-harness.suppressKey",
        "key": "ctrl+k",
        "when": "focusedView == 'opencode-harness.chat' || opencodeHarness.chatFocused"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencode-harness",
          "title": "OpenCode",
          "icon": "media/opencode-activity.svg"
        }
      ]
    },
    "views": {
      "opencode-harness": [
        {
          "id": "opencode-harness.chat",
          "name": "Chat",
          "type": "webview",
          "icon": "media/opencode-activity.svg"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "opencode-harness.showRateLimits",
          "when": "opencodeHarness.chatFocused"
        },
        {
          "command": "opencode-harness.checkCli",
          "when": "opencodeHarness.chatFocused"
        },
        {
          "command": "opencode-harness.installCli",
          "when": "opencodeHarness.chatFocused"
        },
        {
          "command": "opencode-harness.previewTheme",
          "when": "opencodeHarness.chatFocused"
        },
        {
          "command": "opencode-harness.clearTestSessions",
          "when": "false"
        },
        {
          "command": "opencode-harness.openStoredSession",
          "when": "false"
        },
        {
          "command": "opencode-harness.suppressKey",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "opencode-harness.explainCode",
          "group": "opencode@1",
          "when": "editorHasSelection"
        },
        {
          "command": "opencode-harness.refactorCode",
          "group": "opencode@2",
          "when": "editorHasSelection"
        },
        {
          "command": "opencode-harness.generateTests",
          "group": "opencode@3",
          "when": "editorHasSelection"
        },
        {
          "command": "opencode-harness.addSelectionToSession",
          "group": "opencode@4",
          "when": "editorHasSelection"
        }
      ],
      "explorer/context": [
        {
          "command": "opencode-harness.addFileToSession",
          "group": "opencode@1",
          "when": "resourceScheme == file"
        }
      ]
    },
    "configuration": {
      "title": "OpenCode",
      "properties": {
        "opencode.binaryPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Explicit path to the opencode CLI binary. Leave empty to auto-detect from PATH or default install locations (~/.opencode/bin on macOS/Linux, npm global on Windows)."
        },
        "opencode.autoInstall": {
          "type": "string",
          "enum": [
            "prompt",
            "auto",
            "off"
          ],
          "enumDescriptions": [
            "Ask before installing the opencode CLI when it is missing (asks once; remembers if you decline).",
            "Install the opencode CLI automatically and silently when it is missing.",
            "Never install automatically. Use the 'OpenCode: Install CLI' command instead."
          ],
          "default": "prompt",
          "scope": "machine",
          "description": "Controls how the extension installs the required opencode CLI when it is not found. The official installer is used (~/.opencode/bin on macOS/Linux; npm on Windows)."
        },
        "opencode.serverUrl": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "When set, attach to a remote opencode server at this URL instead of spawning a local one (e.g. http://host:4096). Leave blank for local spawn."
        },
        "opencode.serverAuthToken": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Deprecated plaintext fallback for remote server auth. Use the 'OpenCode: Attach Remote Server' command so the token is stored in SecretStorage."
        },
        "opencode.mcpServers": {
          "type": "object",
          "default": {},
          "scope": "window",
          "description": "Legacy fallback MCP server map. OpenCode config files remain the primary source; entries here are used only when no server with the same name exists in opencode.json.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "stdio",
                  "local",
                  "http",
                  "sse",
                  "remote"
                ],
                "description": "MCP transport type. Use 'stdio' or 'local' for locally spawned servers, 'http'/'sse'/'remote' for remote endpoints."
              },
              "command": {
                "type": "string",
                "description": "Command for stdio MCP servers."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Command arguments for stdio MCP servers."
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Environment variables for stdio MCP servers."
              },
              "url": {
                "type": "string",
                "description": "URL for HTTP or SSE MCP servers."
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Request headers for remote MCP servers."
              },
              "disabled": {
                "type": "boolean",
                "description": "Disable this MCP server."
              },
              "enabled": {
                "type": "boolean",
                "description": "Enable this MCP server."
              }
            }
          }
        },
        "opencode.theme": {
          "type": "object",
          "scope": "window",
          "default": {
            "preset": "cli-default",
            "overrides": {}
          },
          "description": "Theme for the OpenCode chat panel. Pick a preset (cli-default, light, dark, high-contrast) and optionally override individual colors. Changes only affect the chat panel — your VS Code editor theme is never modified.",
          "properties": {
            "preset": {
              "type": "string",
              "enum": [
                "cli-default",
                "light",
                "dark",
                "high-contrast",
                "high-contrast-dark",
                "high-contrast-light"
              ],
              "default": "cli-default",
              "description": "Base theme preset"
            },
            "overrides": {
              "type": "object",
              "default": {},
              "description": "Individual color overrides for the theme. All CSS color values are accepted.",
              "properties": {
                "userMessageBg": {
                  "type": "string",
                  "description": "Background color for user messages"
                },
                "userMessageFg": {
                  "type": "string",
                  "description": "Text color for user messages"
                },
                "assistantMessageBg": {
                  "type": "string",
                  "description": "Background color for assistant messages"
                },
                "assistantMessageFg": {
                  "type": "string",
                  "description": "Text color for assistant messages"
                },
                "toolCallColor": {
                  "type": "string",
                  "description": "Color for tool call indicators"
                },
                "toolReadColor": {
                  "type": "string",
                  "description": "Color for read tool calls"
                },
                "toolWriteColor": {
                  "type": "string",
                  "description": "Color for write tool calls"
                },
                "toolExecColor": {
                  "type": "string",
                  "description": "Color for execute tool calls"
                },
                "skillBadgeBg": {
                  "type": "string",
                  "description": "Background color for skill badges"
                },
                "skillBadgeFg": {
                  "type": "string",
                  "description": "Text color for skill badges"
                },
                "thinkingBg": {
                  "type": "string",
                  "description": "Background color for thinking blocks"
                },
                "thinkingBorder": {
                  "type": "string",
                  "description": "Border color for thinking blocks"
                },
                "warningColor": {
                  "type": "string",
                  "description": "Color for warning messages"
                },
                "errorColor": {
                  "type": "string",
                  "description": "Color for error messages"
                },
                "successColor": {
                  "type": "string",
                  "description": "Color for success messages"
                },
                "accentColor": {
                  "type": "string",
                  "description": "Primary accent color"
                },
                "diffAdded": {
                  "type": "string",
                  "description": "Color for added diff lines"
                },
                "diffRemoved": {
                  "type": "string",
                  "description": "Color for removed diff lines"
                },
                "inputBg": {
                  "type": "string",
                  "description": "Background color for input area"
                },
                "inputBorder": {
                  "type": "string",
                  "description": "Border color for input area"
                },
                "mentionBg": {
                  "type": "string",
                  "description": "Background color for mention chips"
                },
                "syntaxComment": {
                  "type": "string",
                  "description": "Syntax highlight color for comments"
                },
                "syntaxKeyword": {
                  "type": "string",
                  "description": "Syntax highlight color for keywords"
                },
                "syntaxString": {
                  "type": "string",
                  "description": "Syntax highlight color for strings"
                },
                "syntaxNumber": {
                  "type": "string",
                  "description": "Syntax highlight color for numbers"
                },
                "syntaxFunction": {
                  "type": "string",
                  "description": "Syntax highlight color for functions"
                },
                "syntaxType": {
                  "type": "string",
                  "description": "Syntax highlight color for types"
                },
                "syntaxOperator": {
                  "type": "string",
                  "description": "Syntax highlight color for operators"
                },
                "primaryColor": {
                  "type": "string",
                  "description": "OpenCode CLI primary color"
                },
                "secondaryColor": {
                  "type": "string",
                  "description": "OpenCode CLI secondary color"
                },
                "infoColor": {
                  "type": "string",
                  "description": "OpenCode CLI info color"
                },
                "elementBg": {
                  "type": "string",
                  "description": "Background color for lower-emphasis UI elements"
                },
                "borderActive": {
                  "type": "string",
                  "description": "Active border color"
                },
                "borderSubtle": {
                  "type": "string",
                  "description": "Subtle border color"
                },
                "diffContext": {
                  "type": "string",
                  "description": "Diff context text color"
                },
                "diffHunkHeader": {
                  "type": "string",
                  "description": "Diff hunk header color"
                },
                "diffHighlightAdded": {
                  "type": "string",
                  "description": "Diff inline added highlight"
                },
                "diffHighlightRemoved": {
                  "type": "string",
                  "description": "Diff inline removed highlight"
                },
                "diffAddedBg": {
                  "type": "string",
                  "description": "Diff added line background"
                },
                "diffRemovedBg": {
                  "type": "string",
                  "description": "Diff removed line background"
                },
                "diffContextBg": {
                  "type": "string",
                  "description": "Diff context line background"
                },
                "diffLineNumber": {
                  "type": "string",
                  "description": "Diff line number color"
                },
                "diffAddedLineNumberBg": {
                  "type": "string",
                  "description": "Diff added line number background"
                },
                "diffRemovedLineNumberBg": {
                  "type": "string",
                  "description": "Diff removed line number background"
                },
                "markdownText": {
                  "type": "string",
                  "description": "Markdown body text color"
                },
                "markdownHeading": {
                  "type": "string",
                  "description": "Markdown heading color"
                },
                "markdownLink": {
                  "type": "string",
                  "description": "Markdown link color"
                },
                "markdownLinkText": {
                  "type": "string",
                  "description": "Markdown link text color"
                },
                "markdownCode": {
                  "type": "string",
                  "description": "Markdown inline code color"
                },
                "markdownBlockQuote": {
                  "type": "string",
                  "description": "Markdown blockquote color"
                },
                "markdownEmph": {
                  "type": "string",
                  "description": "Markdown emphasis color"
                },
                "markdownStrong": {
                  "type": "string",
