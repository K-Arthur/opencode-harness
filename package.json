{
  "name": "opencode-harness",
  "displayName": "OpenCode",
  "publisher": "anomalyco",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/K-Arthur/opencode-harness"
  },
  "description": "The open source coding agent — powered by OpenCode",
  "icon": "media/opencode-icon-256.png",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.98.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true,
      "description": "Requires workspace access to read and modify files"
    }
  },
  "activationEvents": [
    "onView:opencode-harness.chat",
    "onCommand:opencode-harness.openChat"
  ],
  "categories": [
    "Chat",
    "Machine Learning",
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "opencode",
    "ai",
    "coding-agent",
    "chat",
    "llm",
    "assistant",
    "copilot"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "bugs": {
    "url": "https://github.com/K-Arthur/opencode-harness/issues"
  },
  "homepage": "https://github.com/K-Arthur/opencode-harness#readme",
  "extensionKind": [
    "workspace"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "opencode-harness.openChat",
        "title": "OpenCode: Open Chat"
      },
      {
        "command": "opencode-harness.newSession",
        "title": "OpenCode: New Session"
      },
      {
        "command": "opencode-harness.toggleFocus",
        "title": "OpenCode: Toggle Chat Focus"
      },
      {
        "command": "opencode-harness.explainCode",
        "title": "OpenCode: Explain Code"
      },
      {
        "command": "opencode-harness.refactorCode",
        "title": "OpenCode: Refactor Code"
      },
      {
        "command": "opencode-harness.generateTests",
        "title": "OpenCode: Generate Tests"
      },
      {
        "command": "opencode-harness.insertMention",
        "title": "OpenCode: Insert File Reference"
      },
      {
        "command": "opencode-harness.captureTerminal",
        "title": "OpenCode: Capture Terminal Output"
      },
      {
        "command": "opencode-harness.rollback",
        "title": "OpenCode: Rollback Changes"
      },
      {
        "command": "opencode-harness.showRateLimits",
        "title": "OpenCode: Show Rate Limits"
      },
      {
        "command": "opencode-harness.selectModel",
        "title": "OpenCode: Select Model"
      },
      {
        "command": "opencode-harness.checkCli",
        "title": "OpenCode: Check CLI Communication"
      },
      {
        "command": "opencode-harness.listSessions",
        "title": "OpenCode: List Sessions"
      },
      {
        "command": "opencode-harness.openStoredSession",
        "title": "OpenCode: Open Stored Session"
      },
      {
        "command": "opencode-harness.deleteSession",
        "title": "OpenCode: Delete Session"
      },
      {
        "command": "opencode-harness.renameSession",
        "title": "OpenCode: Rename Session"
      },
      {
        "command": "opencode-harness.exportConversation",
        "title": "OpenCode: Export Conversation"
      },
      {
        "command": "opencode-harness.previewTheme",
        "title": "OpenCode: Preview Theme"
      },
      {
        "command": "opencode-harness.clearTestSessions",
        "title": "OpenCode: Clear Test Sessions"
      },
      {
        "command": "opencode-harness.continueLastSession",
        "title": "OpenCode: Continue Last Session"
      },
      {
        "command": "opencode-harness.chooseHistorySession",
        "title": "OpenCode: Choose History Session…"
      },
      {
        "command": "opencode-harness.attachRemote",
        "title": "OpenCode: Attach to Remote Server…"
      },
      {
        "command": "opencode-harness.addFileToSession",
        "title": "OpenCode: Add File to Session"
      },
      {
        "command": "opencode-harness.addSelectionToSession",
        "title": "OpenCode: Add Selection to Session"
      },
      {
        "command": "opencode-harness.stop",
        "title": "OpenCode: Stop"
      }
    ],
    "keybindings": [
      {
        "command": "opencode-harness.toggleFocus",
        "key": "ctrl+alt+o"
      },
      {
        "command": "opencode-harness.newSession",
        "key": "ctrl+alt+n"
      },
      {
        "command": "opencode-harness.insertMention",
        "key": "alt+k",
        "when": "editorTextFocus"
      },
      {
        "command": "opencode-harness.stop",
        "key": "escape",
        "when": "focusedView == 'opencode-harness.chat'"
      },
      {
        "command": "opencode-harness.stop",
        "key": "ctrl+shift+escape",
        "when": "focusedView == 'opencode-harness.chat'"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencode-harness",
          "title": "OpenCode",
          "icon": "media/opencode-activity.svg"
        }
      ]
    },
    "views": {
      "opencode-harness": [
        {
          "id": "opencode-harness.chat",
          "name": "Chat",
          "type": "webview",
          "icon": "media/opencode-activity.svg"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "opencode-harness.explainCode",
          "group": "opencode@1",
          "when": "editorHasSelection"
        },
        {
          "command": "opencode-harness.refactorCode",
          "group": "opencode@2",
          "when": "editorHasSelection"
        },
        {
          "command": "opencode-harness.generateTests",
          "group": "opencode@3",
          "when": "editorHasSelection"
        },
        {
          "command": "opencode-harness.addSelectionToSession",
          "group": "opencode@4",
          "when": "editorHasSelection"
        }
      ],
      "explorer/context": [
        {
          "command": "opencode-harness.addFileToSession",
          "group": "opencode@1",
          "when": "resourceScheme == file"
        }
      ]
    },
    "configuration": {
      "title": "OpenCode",
      "properties": {
        "opencode.binaryPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Path to the opencode binary. If not set, the extension will search for 'opencode' in your PATH."
        },
        "opencode.serverUrl": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "When set, attach to a remote opencode server at this URL instead of spawning a local one (e.g. http://host:4096). Leave blank for local spawn."
        },
        "opencode.serverAuthToken": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Optional bearer token sent with requests to the remote opencode server. Only used when 'opencode.serverUrl' is set."
        },
        "opencode.mcpServers": {
          "type": "object",
          "default": {},
          "scope": "window",
          "description": "Legacy fallback MCP server map. OpenCode config files remain the primary source; entries here are used only when no server with the same name exists in opencode.json.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "stdio",
                  "http",
                  "sse"
                ],
                "description": "MCP transport type."
              },
              "command": {
                "type": "string",
                "description": "Command for stdio MCP servers."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Command arguments for stdio MCP servers."
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Environment variables for stdio MCP servers."
              },
              "url": {
                "type": "string",
                "description": "URL for HTTP or SSE MCP servers."
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Request headers for remote MCP servers."
              },
              "disabled": {
                "type": "boolean",
                "description": "Disable this MCP server."
              },
              "enabled": {
                "type": "boolean",
                "description": "Enable this MCP server."
              }
            }
          }
        },
        "opencode.theme": {
          "type": "object",
          "scope": "window",
          "default": {
            "preset": "cli-default",
            "overrides": {}
          },
          "description": "Theme configuration for the OpenCode chat panel. Set 'preset' to one of: cli-default, light, dark, high-contrast. Add 'overrides' with specific color overrides.",
          "properties": {
            "preset": {
              "type": "string",
              "enum": [
                "cli-default",
                "light",
                "dark",
                "high-contrast"
              ],
              "default": "cli-default",
              "description": "Base theme preset"
            },
            "overrides": {
              "type": "object",
              "default": {},
              "description": "Individual color overrides for the theme. All CSS color values are accepted.",
              "properties": {
                "userMessageBg": {
                  "type": "string",
                  "description": "Background color for user messages"
                },
                "userMessageFg": {
                  "type": "string",
                  "description": "Text color for user messages"
                },
                "assistantMessageBg": {
                  "type": "string",
                  "description": "Background color for assistant messages"
                },
                "assistantMessageFg": {
                  "type": "string",
                  "description": "Text color for assistant messages"
                },
                "toolCallColor": {
                  "type": "string",
                  "description": "Color for tool call indicators"
                },
                "toolReadColor": {
                  "type": "string",
                  "description": "Color for read tool calls"
                },
                "toolWriteColor": {
                  "type": "string",
                  "description": "Color for write tool calls"
                },
                "toolExecColor": {
                  "type": "string",
                  "description": "Color for execute tool calls"
                },
                "skillBadgeBg": {
                  "type": "string",
                  "description": "Background color for skill badges"
                },
                "skillBadgeFg": {
                  "type": "string",
                  "description": "Text color for skill badges"
                },
                "thinkingBg": {
                  "type": "string",
                  "description": "Background color for thinking blocks"
                },
                "thinkingBorder": {
                  "type": "string",
                  "description": "Border color for thinking blocks"
                },
                "warningColor": {
                  "type": "string",
                  "description": "Color for warning messages"
                },
                "errorColor": {
                  "type": "string",
                  "description": "Color for error messages"
                },
                "successColor": {
                  "type": "string",
                  "description": "Color for success messages"
                },
                "accentColor": {
                  "type": "string",
                  "description": "Primary accent color"
                },
                "diffAdded": {
                  "type": "string",
                  "description": "Color for added diff lines"
                },
                "diffRemoved": {
                  "type": "string",
                  "description": "Color for removed diff lines"
                },
                "inputBg": {
                  "type": "string",
                  "description": "Background color for input area"
                },
                "inputBorder": {
                  "type": "string",
                  "description": "Border color for input area"
                },
                "mentionBg": {
                  "type": "string",
                  "description": "Background color for mention chips"
                },
                "syntaxComment": {
                  "type": "string",
                  "description": "Syntax highlight color for comments"
                },
                "syntaxKeyword": {
                  "type": "string",
                  "description": "Syntax highlight color for keywords"
                },
                "syntaxString": {
                  "type": "string",
                  "description": "Syntax highlight color for strings"
                },
                "syntaxNumber": {
                  "type": "string",
                  "description": "Syntax highlight color for numbers"
                },
                "syntaxFunction": {
                  "type": "string",
                  "description": "Syntax highlight color for functions"
                },
                "syntaxType": {
                  "type": "string",
                  "description": "Syntax highlight color for types"
                },
                "syntaxOperator": {
                  "type": "string",
                  "description": "Syntax highlight color for operators"
                },
                "primaryColor": {
                  "type": "string",
                  "description": "OpenCode CLI primary color"
                },
                "secondaryColor": {
                  "type": "string",
                  "description": "OpenCode CLI secondary color"
                },
                "infoColor": {
                  "type": "string",
                  "description": "OpenCode CLI info color"
                },
                "elementBg": {
                  "type": "string",
                  "description": "Background color for lower-emphasis UI elements"
                },
                "borderActive": {
                  "type": "string",
                  "description": "Active border color"
                },
                "borderSubtle": {
                  "type": "string",
                  "description": "Subtle border color"
                },
                "diffContext": {
                  "type": "string",
                  "description": "Diff context text color"
                },
                "diffHunkHeader": {
                  "type": "string",
                  "description": "Diff hunk header color"
                },
                "diffHighlightAdded": {
                  "type": "string",
                  "description": "Diff inline added highlight"
                },
                "diffHighlightRemoved": {
                  "type": "string",
                  "description": "Diff inline removed highlight"
                },
                "diffAddedBg": {
                  "type": "string",
                  "description": "Diff added line background"
                },
                "diffRemovedBg": {
                  "type": "string",
                  "description": "Diff removed line background"
                },
                "diffContextBg": {
                  "type": "string",
                  "description": "Diff context line background"
                },
                "diffLineNumber": {
                  "type": "string",
                  "description": "Diff line number color"
                },
                "diffAddedLineNumberBg": {
                  "type": "string",
                  "description": "Diff added line number background"
                },
                "diffRemovedLineNumberBg": {
                  "type": "string",
                  "description": "Diff removed line number background"
                },
                "markdownText": {
                  "type": "string",
                  "description": "Markdown body text color"
                },
                "markdownHeading": {
                  "type": "string",
                  "description": "Markdown heading color"
                },
                "markdownLink": {
                  "type": "string",
                  "description": "Markdown link color"
                },
                "markdownLinkText": {
                  "type": "string",
                  "description": "Markdown link text color"
                },
                "markdownCode": {
                  "type": "string",
                  "description": "Markdown inline code color"
                },
                "markdownBlockQuote": {
                  "type": "string",
                  "description": "Markdown blockquote color"
                },
                "markdownEmph": {
                  "type": "string",
                  "description": "Markdown emphasis color"
                },
                "markdownStrong": {
                  "type": "string",
                  "description": "Markdown strong text color"
                },
                "markdownHorizontalRule": {
                  "type": "string",
                  "description": "Markdown horizontal rule color"
                },
                "markdownListItem": {
                  "type": "string",
                  "description": "Markdown list item color"
                },
                "markdownListEnumeration": {
                  "type": "string",
                  "description": "Markdown list marker color"
                },
                "markdownImage": {
                  "type": "string",
                  "description": "Markdown image color"
                },
                "markdownImageText": {
                  "type": "string",
                  "description": "Markdown image text color"
                },
                "markdownCodeBlock": {
                  "type": "string",
                  "description": "Markdown fenced code color"
                },
                "syntaxVariable": {
                  "type": "string",
                  "description": "Syntax highlight color for variables"
                },
                "syntaxPunctuation": {
                  "type": "string",
                  "description": "Syntax highlight color for punctuation"
                }
              },
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "opencode.model": {
          "type": "string",
          "default": "",
          "scope": "window",
          "description": "Default model ID in provider/model format (e.g. anthropic/claude-sonnet-4-20250514). Set via 'OpenCode: Select Model' command."
        },
        "opencode.rateLimits": {
          "type": "object",
          "scope": "window",
          "default": {},
          "description": "Fallback rate limit configuration per provider. Set tokensPerMin and requestsPerMin for providers that don't return headers (e.g. openai, anthropic).",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "tokensPerMin": {
                "type": "number",
                "default": 100000,
                "description": "Maximum tokens per minute for this provider"
              },
              "requestsPerMin": {
                "type": "number",
                "default": 50,
                "description": "Maximum requests per minute for this provider"
              }
            }
          }
        },
        "opencode.rateLimitWarningThreshold": {
          "type": "number",
          "scope": "window",
          "default": 0.1,
          "description": "Fraction of remaining rate limit that triggers a warning notification (0.0-1.0)"
        },
        "opencode.rateLimitCriticalThreshold": {
          "type": "number",
          "scope": "window",
          "default": 0.05,
          "description": "Fraction of remaining rate limit that triggers a critical warning (0.0-1.0)"
        },
        "opencode.inlineSuggestions.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "description": "Enable inline ghost-text completions as you type."
        },
        "opencode.inlineSuggestions.triggerDelay": {
          "type": "number",
          "default": 300,
          "scope": "window",
          "description": "Delay in milliseconds before triggering inline completion after typing stops."
        },
        "opencode.autoCompact": {
          "type": "string",
          "scope": "window",
          "default": "ask",
          "enum": [
            "ask",
            "auto",
            "off"
          ],
          "enumDescriptions": [
            "Show a prompt before auto-compacting",
            "Compact automatically without asking",
            "Never auto-compact"
          ],
          "description": "Controls automatic session compaction when context usage reaches 80%"
        },
        "opencode.sessions.emptySessionTtlMinutes": {
          "type": "number",
          "scope": "window",
          "default": 60,
          "minimum": 1,
          "description": "Deletes completely empty, inactive sessions after this many minutes."
        },
        "opencode.sessions.cleanupIntervalMinutes": {
          "type": "number",
          "scope": "window",
          "default": 15,
          "minimum": 1,
          "description": "How often the extension prunes completely empty sessions."
        },
        "opencode.sessions.restoreOpenTabs": {
          "type": "boolean",
          "scope": "window",
          "default": true,
          "description": "Restore chat tabs that were open in this workspace when VS Code last exited."
        },
        "opencode.debugLogging": {
          "type": "boolean",
          "scope": "window",
          "default": false,
          "description": "Enable verbose debug logging to the OpenCode Harness output channel"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run typecheck && node esbuild.js --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --test tests/unit/*.test.mjs && npx tsx --test \"src/**/*.test.ts\"",
    "coverage": "c8 --reporter=text --include='**' --exclude='node_modules/**' --exclude='tests/**' --exclude='.git/**' --exclude='*.json' --exclude='*.md' --exclude='*.yaml' node --test tests/unit/*.test.mjs",
    "test:integration": "vscode-test",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test": "npm run test:unit"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@playwright/test": "^1.49.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.98.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "mocha": "^11.3.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.0"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.14.46",
    "@vscode-elements/elements": "^2.5.1",
    "dompurify": "^3.4.2",
    "fast-diff": "^1.3.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "markdown-it-task-lists": "^2.1.1",
    "simple-git": "^3.27.0"
  }
}
