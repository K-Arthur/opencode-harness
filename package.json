                },
                "markdownHorizontalRule": {
                  "type": "string",
                  "description": "Markdown horizontal rule color"
                },
                "markdownListItem": {
                  "type": "string",
                  "description": "Markdown list item color"
                },
                "markdownListEnumeration": {
                  "type": "string",
