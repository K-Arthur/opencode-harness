import test from "node:test"
import assert from "node:assert/strict"
import { createState } from "../../src/chat/webview/state"

// Mock VsCode API
function createMockVsCodeApi() {
  let storedState: any = null
  return {
    getState: () => storedState,
    setState: (state: any) => { storedState = state },
  }
}

test("state save is debounced", (t) => {
  const mockApi = createMockVsCodeApi()
  const stateManager = createState(mockApi as any)

  // Create a session (triggers save)
  const session = stateManager.createSession("Test")
  assert.ok(session)

  // State should be set (debounced, so might not be immediately set)
  // Wait for debounce
  return new Promise<void>((resolve) => {
    setTimeout(() => {
      const saved = mockApi.getState()
      assert.ok(saved)
      assert.ok(saved.sessions[session.id])
      resolve()
    }, 500) // Wait for 300ms debounce + buffer
  })
})

test("state flush saves immediately", () => {
  const mockApi = createMockVsCodeApi()
  const stateManager = createState(mockApi as any)

  // Create a session
  const session = stateManager.createSession("Test")

  // Flush immediately
  stateManager.flush()

  // State should be saved
  const saved = mockApi.getState()
  assert.ok(saved)
  assert.ok(saved.sessions[session.id])
  assert.equal(saved.sessions[session.id].name, "Test")
})

test("multiple rapid saves are debounced", (t) => {
  const mockApi = createMockVsCodeApi()
  const stateManager = createState(mockApi as any)

  // Create session and make multiple rapid changes
  const session = stateManager.createSession("Test1")
  stateManager.setSessionModel(session.id, "model1")
  stateManager.setSessionMode(session.id, "plan")
  stateManager.setStreaming(session.id, true)

  // Flush manually to verify final state
  stateManager.flush()

  const saved = mockApi.getState()
  assert.equal(saved.sessions[session.id].model, "model1")
  assert.equal(saved.sessions[session.id].mode, "plan")
  assert.equal(saved.sessions[session.id].isStreaming, true)
})

test("state restore works correctly", () => {
  const mockApi = createMockVsCodeApi()

  // Pre-populate state
  mockApi.setState({
    sessions: {
      "test-1": {
        id: "test-1",
        name: "Restored Session",
        model: "test-model",
        mode: "normal",
        messages: [],
        isStreaming: false,
      },
    },
    activeSessionId: "test-1",
    nextSessionNum: 2,
    globalModel: "",
  })

  const stateManager = createState(mockApi as any)
  const restored = stateManager.restore()

  assert.ok(restored)
  assert.equal(stateManager.getSessionCount(), 1)
  assert.ok(stateManager.getSession("test-1"))
})

test("state deleteSession updates active session", () => {
  const mockApi = createMockVsCodeApi()
  const stateManager = createState(mockApi as any)

  const s1 = stateManager.createSession("S1")
  const s2 = stateManager.createSession("S2")

  // Delete active session
  stateManager.deleteSession(s1.id)

  const saved = mockApi.getState()
  assert.ok(!saved.sessions[s1.id])
  assert.ok(saved.sessions[s2.id])
})
