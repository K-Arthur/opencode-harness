{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "mutate": [
    "src/session/EventNormalizer.ts",
    "src/session/eventHandlers/StepFinishHandler.ts",
    "src/session/eventHandlers/ToolPartHandler.ts",
    "src/chat/HostMessageBatcher.ts",
    "src/utils/cssSanitizer.ts"
  ],
  "testRunner": "command",
  "commandRunner": {
    "command": "npx tsx --test 'src/session/EventNormalizer.test.ts' 'src/session/eventHandlers/StepFinishHandler.test.ts' 'src/session/eventHandlers/ToolPartHandler.test.ts' 'src/chat/HostMessageBatcher.test.ts' 'src/utils/cssSanitizer.test.ts'"
  },
  "reporters": ["progress", "html", "clear-text"],
  "concurrency": 4,
  "timeoutMS": 60000,
  "mutator": {
    "excludedMutations": ["StringLiteral", "ObjectLiteral", "ArrayDeclaration"]
  },
  "thresholds": {
    "high": 70,
    "low": 65,
    "break": 50
  }
}
